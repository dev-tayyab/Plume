# Auto detect text files and perform LF normalization
* text=auto eol=lf

# C# / .NET
*.cs text diff=csharp
*.csproj text
*.sln text eol=crlf
*.props text
*.targets text

# Docs
*.md text

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.snk binary
*.nupkg binary
